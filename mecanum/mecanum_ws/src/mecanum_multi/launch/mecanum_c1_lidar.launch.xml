<launch>
	<arg name="robot_name" default="mecanum"/>
	<group>
		<push-ros-namespace namespace="$(var robot_name)"/>
		<!--driver_node-->
		<node name="rplidar_node" pkg="rplidar_ros" exec="rplidar_node" output="screen">
            <param name="channel_type" value="serial" />
            <param name="frame_id" value="$(var robot_name)/laser"/>
            <param name="serial_port" value="/dev/rplidar"/>
            <param name="serial_baudrate" value="460800"/>
            <param name="inverted" value="false"/>
            <param name="angle_compensate" value="true"/>
            <param name="scan_topic" value="scan"/>
            
        </node>
	</group>
</launch>
